# Optional provider configuration. The offline MVP does not require these.
STRATEGY_PROVIDER=manual
OPENAI_API_KEY=replace_with_your_key
DEEPSEEK_API_KEY=replace_with_your_key

# Optional Airtable ingestion. Required only with --source airtable.
AIRTABLE_API_KEY=replace_with_your_airtable_key
AIRTABLE_BASE_ID=replace_with_your_base_id
AIRTABLE_TABLE_ID=replace_with_your_table_id
AIRTABLE_VIEW_ID=replace_with_your_view_id
